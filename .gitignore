# Root-level gitignore for fixit-app-salman

# macOS
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# IDEs and editors
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace

# Laravel
vendor/
node_modules/
.env
.env.*
.phpunit.result.cache
phpunit.xml
phpunit.xml.dist
storage/
bootstrap/cache/*.php
public/storage
.phpstorm.meta.php
.idea/

# Laravel IDE helper
_ide_helper.php
_ide_helper_models.php

# Laravel Swoole / Horizon
horizon.sqlite
horizon.log

# Node/NPM
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

